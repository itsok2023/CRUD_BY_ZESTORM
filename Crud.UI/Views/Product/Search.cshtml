@using Crud.Domain
@model List<Product>

<div class="row">
    <h2 class="text-center">Product Search</h2>

    <form asp-action="Search" asp-controller="Product" method="get" class="border rounded p-3 mb-3">
        <div class="row">
            <div class="col-md-5 form-group">
                <label class="control-label">Category Name</label>
                <select name="categoryName" class="form-control">
                    <option value="">-- All Categories --</option>
                    @foreach (var category in (List<string>)ViewBag.CategoryNames)
                    {
                        if (category == (string)ViewBag.SelectedCategoryName)
                        {
                            <option value="@category" selected="selected">@category</option>
                        }
                        else
                        {
                            <option value="@category">@category</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-5 form-group">
                <label class="control-label">Products Name</label>
                <select name="productName" class="form-control">
                    <option value="">-- All Products --</option>
                    @foreach (var product in (List<string>)ViewBag.ProductNames)
                    {
                        if (product == (string)ViewBag.SelectedProductName)
                        {
                            <option value="@product" selected="selected">@product</option>
                        }
                        else
                        {
                            <option value="@product">@product</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2 form-group d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Search</button>
            </div>
        </div>
    </form>

    <div class="border rounded p-3">
        <h4 class="text-primary">Search Results</h4>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Category Name</th>
                    <th>Product Name</th>
                    <th>Product Price</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>@product.CategoryName</td>
                        <td>@product.ProductName</td>
                        <td>@product.ProductPrice.ToString("C2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <a asp-action="Index" asp-controller="Product" class="btn btn-secondary mt-3 col-md-2">Go Back</a>
</div>
